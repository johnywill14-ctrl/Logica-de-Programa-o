programa {
  funcao inicio() {
    inteiro idade

    escreva("Qual a sua Idade? ")
    leia(idade)

   se (idade >= 65){
    escreva("vc é um idoso.")
   }
   senao se(idade >= 18){
    escreva("vc é um adulto.")
   }

   senao se(idade >= 13){
    escreva("vc é um adolescente.")
   }
   senao{
    escreva("vc é uma criança.")
   }

    
      

     

  

  }
}
